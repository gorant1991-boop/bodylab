# BodyLab AI-прокси — переменные окружения
# Скопировать в .env и заполнить (.env в .gitignore, не коммитить!)

# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx

# Слаг модели OpenRouter — ПРОВЕРИТЬ точное имя на https://openrouter.ai/models
# Claude (рекомендуется для мед-разбора): anthropic/claude-sonnet-4.6
# Дешевле: qwen/qwen-2.5-72b-instruct
AI_MODEL=anthropic/claude-sonnet-4.6

# Порт локального сервера
PORT=8777
